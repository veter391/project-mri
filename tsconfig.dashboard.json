{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "lib": ["DOM", "ES2020"],
    "outDir": "dashboard/dist",
    "rootDir": "dashboard/ts",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "sourceMap": true
  },
  "include": ["dashboard/ts/**/*.ts"]
}
