{
  "name": "project-mri-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multi-page website for Project MRI - local-first codebase intelligence tool",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.dashboard.json",
    "build:site": "tsc",
    "build:dashboard": "tsc -p tsconfig.dashboard.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.dashboard.json --noEmit",
    "watch": "tsc --watch",
    "serve": "python3 -m http.server 8080"
  },
  "keywords": [
    "open-source",
    "code-analysis",
    "git-history",
    "developer-tools"
  ],
  "author": "Project MRI Contributors",
  "license": "MIT",
  "devDependencies": {
    "typescript": "5.9.2"
  }
}
