root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,css,scss,yml,yaml}]
indent_size = 2

[*.md]
# Trailing whitespace is a hard line break in Markdown.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
