<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MRI report — {{ report.project.name }} · project-mri</title>
<meta name="theme-color" content="#06080C">
<style>
:root {
  --ink-void:#06080C; --ink-deep:#0A0D14; --ink-raised:#0F131B;
  --ink-card:#131820; --ink-input:#1A1F2A;
  --line:#1E2330; --line-2:#2A3140;
  --text-primary:#F5F2EA; --text-secondary:#B8B0A0; --text-mute:#7B7468;
  --accent:#F4A847; --accent-deep:#C9753D; --accent-pale:#FFD9A8;
  --accent-soft:rgba(244,168,71,0.10);
  --ok:#7FB069; --warn:#E2B45C; --alert:#D9604E;
  --font: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { background: var(--ink-void); color: var(--text-primary); font-family: var(--font); font-size: 13px; line-height: 1.6; }
body { background-image: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(244,168,71,0.04), transparent 60%); min-height: 100vh; }
.wrap { max-width: 1100px; margin: 0 auto; padding: 64px 32px 96px; }
.bar { display:flex; justify-content: space-between; align-items: center; padding-bottom: 32px; border-bottom: 1px solid var(--line); margin-bottom: 48px; }
.brand { color: var(--accent); font-weight: 700; letter-spacing: 0.04em; }
.meta { color: var(--text-mute); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; }
h1 { font-size: 32px; font-weight: 700; margin-bottom: 8px; }
h2 { font-size: 18px; font-weight: 700; margin: 56px 0 16px; color: var(--accent); letter-spacing: 0.04em; }
h3 { font-size: 14px; font-weight: 700; margin: 24px 0 8px; color: var(--text-primary); }
.sub { color: var(--text-secondary); margin-bottom: 32px; }
.overall { display: flex; align-items: center; gap: 32px; padding: 32px; background: var(--ink-card); border: 1px solid var(--line); margin-bottom: 48px; }
.overall__num { font-size: 96px; font-weight: 700; line-height: 1; color: var(--accent); font-variant-numeric: tabular-nums; }
.overall__band { font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-mute); margin-top: 4px; }
.score-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-bottom: 32px; }
.score { padding: 20px; background: var(--ink-card); border: 1px solid var(--line); }
.score__label { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-mute); margin-bottom: 12px; }
.score__val { font-size: 36px; font-weight: 700; line-height: 1; font-variant-numeric: tabular-nums; }
.score__band { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; margin-top: 4px; }
.score__band--excellent { color: var(--ok); }
.score__band--good      { color: var(--accent-pale); }
.score__band--fair      { color: var(--warn); }
.score__band--poor      { color: var(--alert); }
.score__band--critical  { color: var(--alert); }
.score__bar { height: 4px; background: var(--ink-input); margin-top: 16px; position: relative; overflow: hidden; }
.score__bar-fill { position: absolute; left: 0; top: 0; bottom: 0; background: var(--accent); }
.score__contrib { margin-top: 12px; font-size: 11px; color: var(--text-mute); }
.score__contrib div { padding: 2px 0; }
.findings { display: flex; flex-direction: column; gap: 8px; }
.finding { display: grid; grid-template-columns: 88px 1fr; gap: 16px; padding: 12px 16px; background: var(--ink-card); border-left: 3px solid var(--line-2, #2A3140); align-items: start; }
.finding--critical { border-left-color: var(--alert); }
.finding--high     { border-left-color: var(--alert); }
.finding--medium   { border-left-color: var(--warn); }
.finding--low      { border-left-color: var(--accent-pale); }
.finding--info     { border-left-color: var(--ok); }
.finding__sev { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-mute); padding-top: 2px; }
.finding__title { font-weight: 700; color: var(--text-primary); }
.finding__desc { color: var(--text-secondary); font-size: 12px; margin-top: 4px; }
.finding__path { color: var(--accent); font-size: 11px; margin-top: 4px; font-family: var(--font); }
.fusion { display: flex; flex-direction: column; gap: 8px; }
.fusion__file { padding: 12px 16px; background: var(--ink-card); border-left: 3px solid var(--accent); }
.fusion__path { color: var(--accent); font-weight: 700; font-size: 12px; letter-spacing: 0.02em; }
.fusion__prose { color: var(--text-secondary); font-size: 12px; margin-top: 6px; }
.composition { background: var(--ink-card); border: 1px solid var(--line); padding: 24px; }
.composition div { padding: 6px 0; border-bottom: 1px dashed var(--line); }
.composition div:last-child { border-bottom: none; }
.stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 16px; margin-bottom: 32px; }
.stat { padding: 16px; background: var(--ink-card); border: 1px solid var(--line); }
.stat__label { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-mute); margin-bottom: 6px; }
.stat__val { font-size: 22px; font-weight: 700; font-variant-numeric: tabular-nums; }
.footer { margin-top: 64px; padding-top: 24px; border-top: 1px solid var(--line); color: var(--text-mute); font-size: 11px; }
.lang-bar { display: flex; height: 8px; background: var(--ink-input); margin-top: 12px; overflow: hidden; }
.lang-bar__seg { height: 100%; }
.legend { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 12px; font-size: 11px; }
.legend span::before { content: '■'; margin-right: 6px; }
</style>
</head>
<body>
<div class="wrap">

  <div class="bar">
    <div class="brand">◉ project-mri · report</div>
    <div class="meta">scan · {{ report.scan_uuid[:8] if report.scan_uuid else 'demo' }} · {{ report.finished_at.strftime('%Y-%m-%d %H:%M UTC') if report.finished_at else 'in progress' }}</div>
  </div>

  <h1>{{ report.project.name }}</h1>
  <div class="sub">{{ report.project.path }} · branch {{ report.project.default_branch }} · {{ report.stats.file_count }} files · {{ '{:,}'.format(report.stats.loc_total) }} LOC · {{ report.stats.commit_count }} commits</div>

  <div class="overall">
    <div>
      <div class="overall__num">{{ '%.1f'|format(report.overall_health) }}</div>
      <div class="overall__band">overall · {{ report.overall_band }}</div>
    </div>
    <div style="flex:1; min-width:0;">
      <div style="font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--text-mute); margin-bottom:12px;">How this score is composed</div>
      {% for line in report.composition %}
      <div style="padding:4px 0; color:var(--text-secondary);">{{ line }}</div>
      {% endfor %}
    </div>
  </div>

  <h2>// score breakdown</h2>
  <div class="score-grid">
    {% for s in report.scores %}
    <div class="score">
      <div class="score__label">{{ s.label.replace('_', ' ') }}</div>
      <div class="score__val">{{ '%.1f'|format(s.value) }}</div>
      <div class="score__band score__band--{{ s.band }}">{{ s.band }}</div>
      <div class="score__bar"><div class="score__bar-fill" style="width: {{ s.value }}%"></div></div>
      <div class="score__contrib">
        {% for c in s.contributors %}
        <div>{{ c }}</div>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>

  <h2>// language composition</h2>
  <div class="lang-bar">
    {% set lang_total = (report.stats.languages.values() | sum(attribute='loc')) %}
    {% for lang, data in report.stats.languages.items() %}
    <div class="lang-bar__seg" style="width: {{ (data.loc / lang_total * 100) if lang_total else 0 }}%; background: hsl({{ loop.index * 47 % 360 }}, 60%, 55%);" title="{{ lang }}"></div>
    {% endfor %}
  </div>
  <div class="legend">
    {% for lang, data in report.stats.languages.items() %}
    <span style="color: hsl({{ loop.index0 * 47 % 360 }}, 60%, 55%);">{{ lang }} — {{ '{:,}'.format(data.loc) }} LOC</span>
    {% endfor %}
  </div>

  <h2>// top findings ({{ report.findings|length }} total)</h2>
  <div class="findings">
    {% for f in report.findings[:50] %}
    <div class="finding finding--{{ f.severity }}">
      <div class="finding__sev">{{ f.severity }}{% if f.score %} · {{ '%.0f'|format(f.score) }}{% endif %}</div>
      <div>
        <div class="finding__title">{{ f.title }}</div>
        {% if f.description %}<div class="finding__desc">{{ f.description }}</div>{% endif %}
        {% if f.target_path %}<div class="finding__path">{{ f.target_path }}{% if f.target_symbol %} :: {{ f.target_symbol }}{% endif %}</div>{% endif %}
      </div>
    </div>
    {% endfor %}
  </div>

  {% if fusion %}
  <h2>// AI provenance &amp; decisions ({{ fusion|length }} file{{ 's' if fusion|length != 1 else '' }})</h2>
  <div class="sub">Who authored the riskiest files, traced to sessions, with the decisions and measured consequences behind them. Correlation, never causation.</div>
  <div class="fusion">
    {% for e in fusion %}
    <div class="fusion__file">
      <div class="fusion__path">{{ e.file }}</div>
      <div class="fusion__prose">{{ e.prose }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <div class="footer">
    Generated locally by project-mri v0.2.0 · {{ report.duration_ms }} ms · {{ report.finished_at.isoformat() if report.finished_at else 'in progress' }} · 0 telemetry events
  </div>

</div>
</body>
</html>