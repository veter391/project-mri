{
  "name": "@mri/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "project-mri — the public marketing site. Next.js (App Router, static export) deployed to Cloudflare Workers static assets.",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "dev": "next dev -p 3940",
    "build": "next build && node tools/gen-headers.mjs",
    "start": "next start -p 3940",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "deploy:preview": "pnpm run build && pnpm dlx wrangler@4 deploy --env preview",
    "deploy": "pnpm run build && pnpm dlx wrangler@4 deploy --env production"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "motion": "12.38.0",
    "next": "16.2.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "20.19.41",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "0.6.11",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3"
  }
}
