# ─────────────────────────────────────────────────────────────
# Project MRI — .gitignore
# Hybrid stack: Python (FastAPI backend) + TypeScript (site/dashboard)
# ─────────────────────────────────────────────────────────────

# ── Local-only material — kept on disk, never pushed (delete once stabilized) ──
# raw deliverable zip / backups:
_archive/
# planning & spec docs, local reference only:
preparation-documents/
# internal working area: plans, research, draft docs, reference catalogs:
_workspace/
# project-local Claude config, memory, rules (never publish):
.claude/
*.bak
*.orig
*.tmp
tmp/
scratch/

# ─────────────────────────────────────────────────────────────
# Secrets & environment
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
*.secret

# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
sdist/
wheels/
*.egg-info/
*.egg
.installed.cfg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Testing / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
nosetests.xml

# Type checkers / linters
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ─────────────────────────────────────────────────────────────
# Databases & data stores (local runtime state)
# ─────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.sqlite3-journal
*.db-wal
*.db-shm
data/*.db
src/**/*.db

# ─────────────────────────────────────────────────────────────
# Node / TypeScript
# ─────────────────────────────────────────────────────────────
node_modules/
.npm/
.pnpm-store/
.yarn/
.pnp.*
*.tsbuildinfo
.eslintcache
.cache/
.parcel-cache/

# ─────────────────────────────────────────────────────────────
# Build output — regenerated by `tsc` (see tsconfig* outDir)
# ─────────────────────────────────────────────────────────────
/dist/
dashboard/dist/
*.js.map

# ─────────────────────────────────────────────────────────────
# MRI scan output (generated by CI action / `mri scan`)
# ─────────────────────────────────────────────────────────────
mri-reports/
mri-report.json
mri-report.sarif
*.sarif
coverage.xml

# ─────────────────────────────────────────────────────────────
# Go (optional server component referenced in package.json)
# ─────────────────────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.test
*.out
go.work.sum
vendor/

# ─────────────────────────────────────────────────────────────
# Playwright / E2E test artifacts
# ─────────────────────────────────────────────────────────────
playwright-report/
playwright/.cache/
test-results/
blob-report/

# ─────────────────────────────────────────────────────────────
# Logs & runtime
# ─────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
pids/
*.pid
*.seed

# ─────────────────────────────────────────────────────────────
# Editors / IDE
# ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ─────────────────────────────────────────────────────────────
# OS cruft
# ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
