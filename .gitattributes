# Normalize line endings — LF in the repo, auto on checkout.
# Prevents CRLF churn on Windows checkouts.
* text=auto eol=lf

# Explicitly text
*.py    text eol=lf
*.ts    text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.sql   text eol=lf
*.sh    text eol=lf
*.j2    text eol=lf
*.txt   text eol=lf

# Shell scripts must stay LF regardless
*.sh    text eol=lf

# Binary — never touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.zip   binary
*.pdf   binary
