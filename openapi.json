      "post": {
        "description": "Start a scan.\n\n`project_path` may be either a local filesystem path (e.g. `/home/user/repo`)\nor a git URL (e.g. `https://github.com/owner/name`). URLs are cloned\nautomatically using configured credentials.",
        "operationId": "start_scan_api_scans_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScanRequest"
              }
