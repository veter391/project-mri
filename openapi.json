{
  "components": {
    "schemas": {
      "ChangePasswordRequest": {
        "properties": {
          "current_password": {
            "title": "Current Password",
            "type": "string"
          },
          "new_password": {
            "maxLength": 200,
            "minLength": 8,
            "title": "New Password",
            "type": "string"
          }
        },
        "required": [
          "current_password",
          "new_password"
        ],
        "title": "ChangePasswordRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "db_path": {
            "title": "Db Path",
            "type": "string"
          },
          "status": {
            "const": "ok",
            "default": "ok",
            "title": "Status",
            "type": "string"
          },
          "uptime_seconds": {
            "title": "Uptime Seconds",
            "type": "number"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "version",
          "db_path",
          "uptime_seconds"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "LoginRequest": {
        "properties": {
          "password": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Password",
            "type": "string"
          },
          "username": {
            "maxLength": 64,
            "minLength": 3,
            "title": "Username",
            "type": "string"
          }
        },
        "required": [
          "username",
          "password"
        ],
        "title": "LoginRequest",
        "type": "object"
      },
      "LoginResponse": {
        "properties": {
          "expires_in": {
            "title": "Expires In",
            "type": "integer"
          },
          "token": {
            "title": "Token",
            "type": "string"
          },
          "user": {
            "additionalProperties": true,
            "title": "User",
            "type": "object"
          }
        },
        "required": [
          "token",
          "user",
          "expires_in"
        ],
        "title": "LoginResponse",
        "type": "object"
      },
      "ProjectListResponse": {
        "properties": {
          "count": {
            "title": "Count",
            "type": "integer"
          },
          "projects": {
            "items": {
              "$ref": "#/components/schemas/ProjectSummary"
            },
            "title": "Projects",
            "type": "array"
          }
        },
        "required": [
          "projects",
          "count"
        ],
        "title": "ProjectListResponse",
        "type": "object"
      },
      "ProjectSummary": {
        "description": "One project, as listed by GET /api/projects.",
        "properties": {
          "default_branch": {
            "default": "main",
            "title": "Default Branch",
            "type": "string"
          },
          "file_count": {
            "default": 0,
            "title": "File Count",
            "type": "integer"
          },
          "first_scanned": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "First Scanned"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "last_commit": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Commit"
          },
          "last_scanned": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Scanned"
          },
          "loc_total": {
            "default": 0,
            "title": "Loc Total",
            "type": "integer"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "path": {
            "title": "Path",
            "type": "string"
          }
        },
        "required": [
          "id",
          "path",
          "name"
        ],
        "title": "ProjectSummary",
        "type": "object"
      },
      "ScanAccepted": {
        "properties": {
          "project_name": {
            "title": "Project Name",
            "type": "string"
          },
          "project_path": {
            "title": "Project Path",
            "type": "string"
          },
          "scan_uuid": {
            "title": "Scan Uuid",
            "type": "string"
          },
          "started_at": {
            "format": "date-time",
            "title": "Started At",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/ScanStatus",
            "default": "pending"
          },
          "stream_url": {
            "title": "Stream Url",
            "type": "string"
          }
        },
        "required": [
          "scan_uuid",
          "project_name",
          "project_path",
          "started_at",
          "stream_url"
        ],
        "title": "ScanAccepted",
        "type": "object"
      },
      "ScanListResponse": {
        "description": "Response of GET /api/scans.\n\nDeclared explicitly so the database's column names never become the public\nAPI \u2014 the endpoint used to return raw SQLite rows, which both leaked the\nfull report blob into a list view and made every schema change a breaking\nAPI change.",
        "properties": {
          "count": {
            "title": "Count",
            "type": "integer"
          },
          "scans": {
            "items": {
              "$ref": "#/components/schemas/ScanSummary"
            },
            "title": "Scans",
            "type": "array"
          }
        },
        "required": [
          "scans",
          "count"
        ],
        "title": "ScanListResponse",
        "type": "object"
      },
      "ScanRequest": {
        "properties": {
          "branch": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Branch"
          },
          "exclude_globs": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Exclude Globs"
          },
          "include_globs": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Include Globs"
          },
          "project_path": {
            "description": "Absolute path to the repo to scan",
            "title": "Project Path",
            "type": "string"
          }
        },
        "required": [
          "project_path"
        ],
        "title": "ScanRequest",
        "type": "object"
      },
      "ScanStatus": {
        "enum": [
          "pending",
          "running",
          "completed",
          "failed"
        ],
        "title": "ScanStatus",
        "type": "string"
      },
      "ScanSummary": {
        "description": "Short version, for indexes and listing.",
        "properties": {
          "commit_count": {
            "default": 0,
            "title": "Commit Count",
            "type": "integer"
          },
          "duration_ms": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Duration Ms"
          },
          "file_count": {
            "default": 0,
            "title": "File Count",
            "type": "integer"
          },
          "finding_counts": {
            "additionalProperties": {
              "type": "integer"
            },
            "title": "Finding Counts",
            "type": "object"
          },
          "finished_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Finished At"
          },
          "loc_total": {
            "default": 0,
            "title": "Loc Total",
            "type": "integer"
          },
          "overall_band": {
            "default": "fair",
            "title": "Overall Band",
            "type": "string"
          },
          "overall_health": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Overall Health"
          },
          "project_name": {
            "title": "Project Name",
            "type": "string"
          },
          "project_path": {
            "title": "Project Path",
            "type": "string"
          },
          "scan_uuid": {
            "title": "Scan Uuid",
            "type": "string"
          },
          "started_at": {
            "format": "date-time",
            "title": "Started At",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/ScanStatus"
          }
        },
        "required": [
          "scan_uuid",
          "project_name",
          "project_path",
          "status",
          "started_at"
        ],
        "title": "ScanSummary",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "WhoAmIResponse": {
        "properties": {
          "created_at": {
            "title": "Created At",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "last_login_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Login At"
          },
          "username": {
            "title": "Username",
            "type": "string"
          }
        },
        "required": [
          "id",
          "username",
          "created_at",
          "last_login_at"
        ],
        "title": "WhoAmIResponse",
        "type": "object"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Local-first codebase intelligence. Analyzes Git history, architecture, dependencies, complexity, tech debt, and coupling \u2014 then produces an explainable report.",
    "title": "project-mri",
    "version": "0.3.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/auth/change-password": {
      "post": {
        "description": "Change the current user's password.",
        "operationId": "change_password_api_auth_change_password_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Change Password Api Auth Change Password Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "Change Password",
        "tags": [
          "auth"
        ]
      }
    },
